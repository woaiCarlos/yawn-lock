<?xml version="1.0" encoding="utf-8"?>
<!--
  bubble_pin_bg
  =========
  Line-state 背景:贴在屏幕边缘的「紫色圆柱体」。
  - 横向渐变(left 暗 → center 亮 → right 暗)模拟圆柱体表面的高光,3D 感更强
  - 4dp 宽 + 50dp 高(配合 OuterLayout LinearLayout),小尺寸下不会被认成"方形边框"
  - 上下 8dp 圆角、左右 2dp 圆角,让 4dp × 50dp 的形状视觉上像「拉长的胶囊」而非「瘦长方形」
  - 颜色继承 brand purple;start/end 用 #2D2466(更深的紫)做圆柱两侧阴影,center #9F87D4 做受光面
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="0"
        android:startColor="#2D2466"
        android:centerColor="#9F87D4"
        android:endColor="#2D2466" />
    <corners
        android:topLeftRadius="8dp"
        android:bottomLeftRadius="8dp"
        android:topRightRadius="8dp"
        android:bottomRightRadius="8dp" />
</shape>

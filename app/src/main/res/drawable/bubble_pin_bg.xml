<?xml version="1.0" encoding="utf-8"?>
<!--
  bubble_pin_bg
  =========
  Line-state 背景:贴在屏幕边缘的「纯紫色圆柱体」。

  - 4dp 宽 × 50dp 高 + 8dp 圆角(4dp 宽上 cap 到 2dp 实际圆角),
    视觉上是一根拉长胶囊,代表圆柱体
  - 纯色 #4A3580(品牌紫 #2D2466 / #6750A4 的中段)清晰可辨,
    不再使用 3-stop 渐变 —— 实测 4dp 宽元素下,渐变的 3 个色带会
    看起来像「条形码 / 分段」,反而失去圆柱体观感
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#4A3580" />
    <corners
        android:topLeftRadius="8dp"
        android:bottomLeftRadius="8dp"
        android:topRightRadius="8dp"
        android:bottomRightRadius="8dp" />
</shape>
